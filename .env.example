# Talos MCP Server - Configuration

# Path to talosconfig (default: ~/.talos/config)
# TALOSCONFIG=/path/to/talosconfig

# Context name to use from talosconfig (defaults to current context)
# TALOS_CONTEXT=my-cluster

# Override endpoints (comma-separated, overrides talosconfig endpoints)
# TALOS_ENDPOINTS=192.168.1.10:50000,192.168.1.11:50000

# Default nodes to target when tools are called without explicit nodes
# TALOS_NODES=192.168.1.10,192.168.1.11,192.168.1.12
